{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "kanade",
  "version": "0.1.0",
  "identifier": "com.yushin.kanade",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Kanade",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: ipc:; connect-src 'self' wss://generativelanguage.googleapis.com; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
